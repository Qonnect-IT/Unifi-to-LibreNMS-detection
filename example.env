# Optional, when mounting host CA store:
# REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
# SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

UNIFI_URL=https://cloudkey.example.local
UNIFI_USERNAME=librenms-sync
UNIFI_PASSWORD=change-me
UNIFI_SITES=default
UNIFI_VERIFY_SSL=true
# Optional, when using internal PKI:
# UNIFI_CA_BUNDLE=/certs/internal-ca-bundle.crt

LIBRENMS_URL=https://librenms.example.local
LIBRENMS_TOKEN=change-me
LIBRENMS_POLLER_GROUP=2
LIBRENMS_VERIFY_SSL=true
# Optional, when using internal PKI:
# LIBRENMS_CA_BUNDLE=/certs/internal-ca-bundle.crt

HOSTNAME_MODE=dns
HOSTNAME_DOMAIN=mgmt.example.local

SNMP_VERSION=v2c
SNMP_COMMUNITY=your-community

PING_FALLBACK=true
FORCE_ADD=false
DRY_RUN=true
